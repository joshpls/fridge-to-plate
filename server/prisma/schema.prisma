// server/prisma/schema.prisma
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  password       String
  role           String       @default("USER")
  firstName      String?
  lastName       String?
  alias          String?
  pantry         PantryItem[]
  favorites      Favorite[]
  comments       Comment[]
  createdRecipes Recipe[]     @relation("UserRecipes")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt
}

model Ingredient {
  id                String             @id @default(uuid())
  name              String             @unique
  isStaple          Boolean            @default(false)
  pantryItems       PantryItem[]
  recipeIngredients RecipeIngredient[]
}

model PantryItem {
  id           String     @id @default(uuid())
  userId       String
  ingredientId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @default(now()) @updatedAt

  @@unique([userId, ingredientId])
}

model Recipe {
  id           String  @id @default(uuid())
  name         String
  slug         String  @unique
  summary      String? @db.Text // NEW: Short description
  instructions String  @db.Text
  imageUrl     String?

  prepTime  Int?
  cookTime  Int?
  totalTime Int?
  servings  Int  @default(1)

  notes     String? @db.Text // Optional chef notes
  nutrition Json? // e.g., { "calories": 500, "protein": "25g", "fat": "15g" }

  authorId String
  author   User   @relation("UserRecipes", fields: [authorId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)

  tags        Tag[]              @relation("RecipeTags")
  ingredients RecipeIngredient[]
  favorites   Favorite[]
  comments    Comment[]
  createdAt   DateTime           @default(now())
}

model Category {
  id            String        @id @default(uuid())
  name          String        @unique
  subcategories Subcategory[]
  recipes       Recipe[]
}

model Subcategory {
  id   String @id @default(uuid())
  name String @unique

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  recipes Recipe[]
}

model Tag {
  id      String   @id @default(uuid())
  name    String   @unique // e.g., "Vegan"
  code    String   @unique // e.g., "V"
  recipes Recipe[] @relation("RecipeTags")
}

model Unit {
  id                String             @id @default(uuid())
  name              String             @unique // e.g., "Cup", "Teaspoon", "Gram", "Whole"
  abbreviation      String? // e.g., "c", "tsp", "g"
  recipeIngredients RecipeIngredient[]
}

model RecipeIngredient {
  id           String @id @default(uuid())
  recipeId     String
  ingredientId String
  unitId       String // NEW: Link to Unit
  amount       Float // NEW: Changed from String to Float (e.g., 1.5 instead of "1 1/2")

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  unit       Unit       @relation(fields: [unitId], references: [id])
}

model Favorite {
  userId   String
  recipeId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@id([userId, recipeId])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  rating    Int? // Optional 1-5 star rating
  userId    String
  recipeId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
