datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// Enums
enum HouseholdRole {
  OWNER
  ADMIN
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REJECTED
}

enum Visibility {
  PRIVATE
  HOUSEHOLD
  PUBLIC
}

model User {
  id        String  @id @default(uuid())
  email     String  @unique
  password  String
  role      String  @default("USER")
  firstName String?
  lastName  String?
  alias     String?

  activeHouseholdId String?
  activeHousehold   Household? @relation(fields: [activeHouseholdId], references: [id])

  preferences Json? @default("{\"darkMode\": false, \"cookMode\": true, \"autoTTS\": false}")

  households       HouseholdMember[]
  addedPantryItems PantryItem[]      @relation("AddedBy")

  favorites      Favorite[]
  comments       Comment[]
  createdRecipes Recipe[]   @relation("UserRecipes")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Household {
  id   String @id @default(uuid())
  name String

  members     HouseholdMember[]
  invites     HouseholdInvite[]
  pantryItems PantryItem[]
  recipes     Recipe[]          @relation("HouseholdRecipes")
  users       User[]
  favorites   Favorite[]        @relation("HouseholdFavorites")
  staples     HouseholdStaple[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model HouseholdMember {
  id          String        @id @default(uuid())
  userId      String
  householdId String
  role        HouseholdRole @default(MEMBER)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([userId, householdId])
}

model HouseholdInvite {
  id          String       @id @default(uuid())
  householdId String
  email       String
  token       String       @unique
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

model IngredientCategory {
  id          String       @id @default(uuid())
  name        String       @unique
  order       Int          @default(0) // Control display order (e.g., Produce first)
  ingredients Ingredient[]
}

// Smart Substitution Groups (e.g., "Neutral Oils", "Citrus")
model SubstitutionGroup {
  id          String       @id @default(uuid())
  name        String       @unique
  ingredients Ingredient[]
}

model Ingredient {
  id                String             @id @default(uuid())
  name              String             @unique
  isDefaultStaple   Boolean            @default(false)
  
  categoryId        String?
  category          IngredientCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  
  subGroupId        String?
  subGroup          SubstitutionGroup?  @relation(fields: [subGroupId], references: [id], onDelete: SetNull)

  pantryItems       PantryItem[]
  recipeIngredients RecipeIngredient[]
  householdStaples  HouseholdStaple[]  // [NEW]

  @@index([categoryId])
  @@index([subGroupId])
}

model HouseholdStaple {
  id           String     @id @default(uuid())
  householdId  String
  ingredientId String
  
  household    Household  @relation(fields: [householdId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([householdId, ingredientId])
}

model PantryItem {
  id           String @id @default(uuid())
  householdId  String
  ingredientId String

  addedById    String?
  addedBy      User?   @relation("AddedBy", fields: [addedById], references: [id], onDelete: SetNull)

  quantity     Float?
  unitId       String?
  unit         Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  expiresAt    DateTime?

  household    Household  @relation(fields: [householdId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@unique([householdId, ingredientId])
  @@index([householdId, expiresAt])
}

model Recipe {
  id           String  @id @default(uuid())
  name         String
  slug         String  @unique
  summary      String? @db.Text
  instructions String  @db.Text
  imageUrl     String?

  prepTime  Int?
  cookTime  Int?
  totalTime Int?
  servings  Int  @default(1)

  notes     String? @db.Text
  nutrition Json?

  sourceName String?
  sourceUrl  String?

  authorId String
  author   User   @relation("UserRecipes", fields: [authorId], references: [id], onDelete: Cascade)

  visibility  Visibility @default(PRIVATE)
  householdId String?
  household   Household? @relation("HouseholdRecipes", fields: [householdId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)

  tags        Tag[]              @relation("RecipeTags")
  ingredients RecipeIngredient[]
  favorites   Favorite[]
  comments    Comment[]
  createdAt   DateTime           @default(now())
}

model Category {
  id            String        @id @default(uuid())
  name          String        @unique
  subcategories Subcategory[]
  recipes       Recipe[]
}

model Subcategory {
  id         String   @id @default(uuid())
  name       String   @unique
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  recipes    Recipe[]
}

model Tag {
  id      String   @id @default(uuid())
  name    String   @unique
  code    String   @unique
  recipes Recipe[] @relation("RecipeTags")
}

model Unit {
  id                String             @id @default(uuid())
  name              String             @unique
  abbreviation      String?
  recipeIngredients RecipeIngredient[]
  pantryItems       PantryItem[]
}

model RecipeIngredient {
  id           String @id @default(uuid())
  recipeId     String
  ingredientId String
  unitId       String
  amount       Float
  sectionName  String?
  order        Int    @default(0)

  modifierId String?
  modifier   Modifier? @relation(fields: [modifierId], references: [id], onDelete: SetNull)

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  unit       Unit       @relation(fields: [unitId], references: [id])
}

model Favorite {
  userId      String
  recipeId    String
  householdId String?
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe      Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  household   Household? @relation("HouseholdFavorites", fields: [householdId], references: [id], onDelete: Cascade)

  @@id([userId, recipeId])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  rating    Int?
  userId    String
  recipeId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Modifier {
  id                String             @id @default(uuid())
  name              String             @unique
  recipeIngredients RecipeIngredient[]
}
